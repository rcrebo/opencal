# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=bookings@yourdomain.com

# Admin session signing secret (generate with: openssl rand -base64 32)
ADMIN_SECRET=change-me-to-a-random-secret

# Booking access key (shared secret in booking URLs)
BOOKING_SECRET=change-me

# App URL
NEXT_PUBLIC_APP_URL=https://your-domain.com
